# Valores abaixo sao placeholders de exemplo. Troque as senhas antes de usar
# este ambiente para qualquer coisa alem de teste local.
POSTGRES_DB=zabbix
POSTGRES_USER=zabbix
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA_POSTGRES

ZABBIX_WEB_PORT=8080
ZABBIX_SERVER_PORT=10061
ZABBIX_AGENT_PORT=10060
GRAFANA_PORT=3001
PHP_TZ=America/Sao_Paulo

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=TROQUE_ESTA_SENHA_GRAFANA
ZABBIX_API_USER=Admin
# Deve ser mantida igual a senha atual do usuario Admin no Zabbix (o padrao de
# fabrica do Zabbix e "zabbix"). Se trocar a senha do Admin pela interface web,
# atualize este valor tambem e recrie o container do grafana, ou o datasource
# Zabbix do Grafana para de autenticar.
ZABBIX_API_PASSWORD=zabbix

ZBX_AGENT_HOSTNAME=zabbix-agent
ZBX_STARTPOLLERS=10
ZBX_STARTPINGERS=5
ZBX_CACHESIZE=64M
ZBX_HISTORYCACHESIZE=32M
ZBX_TIMEOUT=4
